generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum UnitType {
  KG
  GRAM
  PIECE
  BUNCH
  PACKET
  BUNDLE
}

enum ChangeType {
  RESTOCK
  SALE
  ADJUSTMENT
  WASTAGE
}

enum StaffRole {
  PRODUCER
  SUPPLIER
  TRANSPORTER
}

enum PaymentMethod {
  CASH
  UPI
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERPAID
}

enum WeightClass {
  HEAVY
  MEDIUM
  LIGHT
  DELICATE
}

enum RefrigeratorStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum TransactionType {
  LOAD
  PICKUP
  ADJUSTMENT
}

enum FridgeOrderStatus {
  PENDING
  CONFIRMED
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum OrderType {
  FRIDGE_PICKUP
  HOME_DELIVERY
}

enum NotificationType {
  ORDER_MODIFIED
  ORDER_CONFIRMED
  ORDER_READY
  ORDER_CANCELLED
  LOW_STOCK
}

model Customer {
  id          String   @id @default(uuid())
  phone       String   @unique
  name        String?
  whatsapp    String?
  address     String?
  firebaseUid String?  @unique @map("firebase_uid")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders           Order[]
  favorites        Favorite[]
  addresses        Address[]
  fridgePickupOrders FridgePickupOrder[]
  notifications    Notification[]

  @@map("customers")
}

model AdminUser {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String?
  name        String
  firebaseUid String?  @unique @map("firebase_uid")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  payments Payment[]

  @@map("admin_users")
}

model StaffUser {
  id          String    @id @default(uuid())
  name        String
  phone       String?
  email       String    @unique
  role        StaffRole
  firebaseUid String?   @unique @map("firebase_uid")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  assignedFridges      ProducerFridgeAssignment[]
  assignedFridgeOrders FridgePickupOrder[]        @relation("AssignedToStaff")

  @@map("staff_users")
}

model Category {
  id          String       @id @default(uuid())
  name        String       @unique
  nameHindi   String?      @map("name_hindi")
  nameKannada String?      @map("name_kannada")
  image       String?
  sortOrder   Int          @default(0) @map("sort_order")
  weightClass WeightClass  @default(MEDIUM) @map("weight_class")
  createdAt   DateTime     @default(now()) @map("created_at")

  vegetables Vegetable[]

  @@map("categories")
}

model DeliveryZone {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("delivery_zones")
}

model Vegetable {
  id            String   @id @default(uuid())
  name          String
  nameHindi     String?  @map("name_hindi")
  nameKannada   String?  @map("name_kannada")
  image         String?
  emoji         String?
  description   String?
  available     Boolean  @default(true)
  featured      Boolean  @default(false)
  stockKg       Decimal  @default(0) @map("stock_kg") @db.Decimal(10, 3)
  minStockAlert Decimal  @default(5) @map("min_stock_alert") @db.Decimal(10, 3)
  categoryId    String   @map("category_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category              Category                @relation(fields: [categoryId], references: [id])
  prices                Price[]
  orderItems            OrderItem[]
  favorites             Favorite[]
  priceHistory          PriceHistory[]
  inventoryLogs         InventoryLog[]
  fridgeInventory       RefrigeratorInventory[]
  fridgeTransactions    RefrigeratorTransaction[]
  fridgePickupItems     FridgePickupItem[]

  @@map("vegetables")
}

model Price {
  id               String   @id @default(uuid())
  vegetableId      String   @map("vegetable_id")
  pricePerKg       Decimal? @map("price_per_kg") @db.Decimal(10, 2)
  originalPricePerKg Decimal? @map("original_price_per_kg") @db.Decimal(10, 2)
  pricePerPiece    Decimal? @map("price_per_piece") @db.Decimal(10, 2)
  pricePerPacket   Decimal? @map("price_per_packet") @db.Decimal(10, 2)
  pricePerBundle   Decimal? @map("price_per_bundle") @db.Decimal(10, 2)
  pricePerBunch    Decimal? @map("price_per_bunch") @db.Decimal(10, 2)
  packetWeight     Decimal? @map("packet_weight") @db.Decimal(10, 3)
  effectiveFrom    DateTime @default(now()) @map("effective_from")
  createdAt        DateTime @default(now()) @map("created_at")

  vegetable Vegetable @relation(fields: [vegetableId], references: [id])

  @@map("prices")
}

model Order {
  id             String        @id @default(uuid())
  orderNumber    String        @unique @map("order_number")
  customerId     String        @map("customer_id")
  status         OrderStatus   @default(PENDING)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(10, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  address        String?
  deliveryZoneId String?       @map("delivery_zone_id")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  customer      Customer       @relation(fields: [customerId], references: [id])
  deliveryZone  DeliveryZone?  @relation(fields: [deliveryZoneId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  inventoryLogs InventoryLog[]

  @@map("orders")
}

model Payment {
  id                 String        @id @default(uuid())
  orderId            String?       @map("order_id")
  fridgePickupOrderId String?      @map("fridge_pickup_order_id")
  amount             Decimal       @db.Decimal(10, 2)
  method             PaymentMethod
  reference          String?
  screenshotUrl      String?       @map("screenshot_url")
  notes              String?
  loggedById         String        @map("logged_by_id")
  receivedAt         DateTime      @default(now()) @map("received_at")
  createdAt          DateTime      @default(now()) @map("created_at")

  order            Order?            @relation(fields: [orderId], references: [id])
  fridgePickupOrder FridgePickupOrder? @relation(fields: [fridgePickupOrderId], references: [id])
  loggedBy         AdminUser          @relation(fields: [loggedById], references: [id])

  @@map("payments")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  vegetableId String   @map("vegetable_id")
  quantity    Decimal  @db.Decimal(10, 3)
  unit        UnitType
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(10, 2)

  order     Order     @relation(fields: [orderId], references: [id])
  vegetable Vegetable @relation(fields: [vegetableId], references: [id])

  @@map("order_items")
}

model Favorite {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  vegetableId String   @map("vegetable_id")
  createdAt   DateTime @default(now()) @map("created_at")

  customer  Customer  @relation(fields: [customerId], references: [id])
  vegetable Vegetable @relation(fields: [vegetableId], references: [id])

  @@unique([customerId, vegetableId])
  @@map("favorites")
}

model PriceHistory {
  id          String   @id @default(uuid())
  vegetableId String   @map("vegetable_id")
  oldPrice    Decimal? @map("old_price") @db.Decimal(10, 2)
  newPrice    Decimal  @map("new_price") @db.Decimal(10, 2)
  changedAt   DateTime @default(now()) @map("changed_at")

  vegetable Vegetable @relation(fields: [vegetableId], references: [id])

  @@map("price_history")
}

model Address {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  label      String
  text       String
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fridgePickupOrders FridgePickupOrder[]

  @@map("addresses")
}

model InventoryLog {
  id          String     @id @default(uuid())
  vegetableId String     @map("vegetable_id")
  orderId     String?    @map("order_id")
  changeType  ChangeType @map("change_type")
  quantity    Decimal    @db.Decimal(10, 3)
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")

  vegetable Vegetable @relation(fields: [vegetableId], references: [id])
  order     Order?    @relation(fields: [orderId], references: [id])

  @@map("inventory_logs")
}

// ─── Refrigerator Module ────────────────────────────────────────────

model Location {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refrigerators Refrigerator[]

  @@map("locations")
}

model Refrigerator {
  id         String             @id @default(uuid())
  locationId String             @map("location_id")
  name       String
  status     RefrigeratorStatus @default(ACTIVE)
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  location          Location                  @relation(fields: [locationId], references: [id])
  inventory         RefrigeratorInventory[]
  transactions      RefrigeratorTransaction[]
  pickupOrders      FridgePickupOrder[]
  assignedProducers ProducerFridgeAssignment[]

  @@map("refrigerators")
}

model RefrigeratorInventory {
  id                String   @id @default(uuid())
  refrigeratorId    String   @map("refrigerator_id")
  vegetableId       String   @map("vegetable_id")
  quantityAvailable Decimal  @default(0) @map("quantity_available") @db.Decimal(10, 3)
  minimumThreshold  Decimal  @default(2) @map("minimum_threshold") @db.Decimal(10, 3)
  lastUpdatedAt     DateTime @default(now()) @map("last_updated_at")

  refrigerator Refrigerator @relation(fields: [refrigeratorId], references: [id])
  vegetable    Vegetable    @relation(fields: [vegetableId], references: [id])

  @@unique([refrigeratorId, vegetableId])
  @@map("refrigerator_inventory")
}

model RefrigeratorTransaction {
  id             String          @id @default(uuid())
  refrigeratorId String          @map("refrigerator_id")
  vegetableId    String          @map("vegetable_id")
  quantity       Decimal         @db.Decimal(10, 3)
  type           TransactionType
  userId         String          @map("user_id")
  userRole       String          @map("user_role")
  note           String?
  createdAt      DateTime        @default(now()) @map("created_at")

  refrigerator Refrigerator @relation(fields: [refrigeratorId], references: [id])
  vegetable    Vegetable    @relation(fields: [vegetableId], references: [id])

  @@map("refrigerator_transactions")
}

model FridgePickupOrder {
  id              String            @id @default(uuid())
  orderNumber     String            @unique @map("order_number")
  customerId      String            @map("customer_id")
  refrigeratorId  String?           @map("refrigerator_id")
  orderType       OrderType         @default(FRIDGE_PICKUP) @map("order_type")
  addressId       String?           @map("address_id")
  status          FridgeOrderStatus @default(PENDING)
  totalAmount     Decimal           @map("total_amount") @db.Decimal(10, 2)
  paidAmount      Decimal           @default(0) @map("paid_amount") @db.Decimal(10, 2)
  paymentStatus   PaymentStatus     @default(UNPAID) @map("payment_status")
  assignedToId    String?           @map("assigned_to_id")
  notes           String?
  confirmedAt     DateTime?         @map("confirmed_at")
  readyAt         DateTime?         @map("ready_at")
  pickedUpAt      DateTime?         @map("picked_up_at")
  deliveredAt     DateTime?         @map("delivered_at")
  cancelledAt     DateTime?         @map("cancelled_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  customer     Customer         @relation(fields: [customerId], references: [id])
  refrigerator Refrigerator?    @relation(fields: [refrigeratorId], references: [id])
  address      Address?         @relation(fields: [addressId], references: [id])
  assignedTo   StaffUser?       @relation("AssignedToStaff", fields: [assignedToId], references: [id])
  items        FridgePickupItem[]
  payments     Payment[]

  @@map("fridge_pickup_orders")
}

model FridgePickupItem {
  id               String   @id @default(uuid())
  pickupOrderId    String   @map("pickup_order_id")
  vegetableId      String   @map("vegetable_id")
  quantity         Decimal  @db.Decimal(10, 3)
  originalQuantity Decimal? @map("original_quantity") @db.Decimal(10, 3)
  unit             UnitType
  unitPrice        Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice       Decimal  @map("total_price") @db.Decimal(10, 2)
  isRemoved        Boolean  @default(false) @map("is_removed")
  removalReason    String?  @map("removal_reason")

  pickupOrder FridgePickupOrder @relation(fields: [pickupOrderId], references: [id])
  vegetable   Vegetable         @relation(fields: [vegetableId], references: [id])

  @@map("fridge_pickup_items")
}

model ProducerFridgeAssignment {
  id             String   @id @default(uuid())
  staffUserId    String   @map("staff_user_id")
  refrigeratorId String   @map("refrigerator_id")
  createdAt      DateTime @default(now()) @map("created_at")

  staffUser    StaffUser    @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  refrigerator Refrigerator @relation(fields: [refrigeratorId], references: [id], onDelete: Cascade)

  @@unique([staffUserId, refrigeratorId])
  @@map("producer_fridge_assignments")
}

model Notification {
  id         String           @id @default(cuid())
  customerId String           @map("customer_id")
  orderId    String?          @map("order_id")
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isRead])
  @@map("notifications")
}
